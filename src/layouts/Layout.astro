---
import '@fontsource-variable/eb-garamond';
import '../styles/global.css';
import {
	ui,
	routes,
	getLocale,
	normalizePath,
	routeKeyOf,
	htmlLang,
	dir,
	ogLocale,
	hreflang,
	localeName,
	LOCALES,
} from '../i18n/ui';

interface Props {
	title?: string;
	description?: string;
}

const {
	title = 'Shivapuri Baba',
	description = 'An open, non-profit resource on the life, teachings, and legacy of Shivapuri Baba (1826–1963).',
} = Astro.props;

const site = Astro.site ?? Astro.url;

// Canonical / Open Graph URL, resolved against the configured site.
const canonicalURL = new URL(Astro.url.pathname, site);

// Absolute URL for the social share image (must be absolute for Open Graph).
const ogImageURL = new URL('/og.jpg', site).href;

// Current path (trailing slash removed) for matching routes and the active nav item.
const current = normalizePath(Astro.url.pathname);

// Which language this page is, and the strings/labels that follow from it.
const locale = getLocale(current);
const t = ui[locale];
const homePath = routes.home[locale];

// Resolve the nav items for this locale to their localized URLs.
const navItems = t.nav.map((item) => ({ href: routes[item.key][locale], label: item.label }));

// A nav item is active for its own page and for any page beneath it.
const isActive = (href: string) =>
	href === homePath ? current === homePath : current === href || current.startsWith(href + '/');

// The equivalent page in each language, for the switcher and hreflang. Pages
// outside the route map (e.g. 404) have no pair, so fall back to each home.
const routeKey = routeKeyOf(current);
const localeHref = (loc: (typeof LOCALES)[number]) =>
	routeKey ? routes[routeKey][loc] : routes.home[loc];

// hreflang alternates (only for paired pages), with x-default → English.
const alternates = routeKey
	? LOCALES.map((loc) => ({
			hreflang: hreflang[loc],
			href: new URL(routes[routeKey][loc], site).href,
		}))
	: [];
const xDefaultHref = routeKey ? new URL(routes[routeKey].en, site).href : null;

const ogImageAlt =
	locale === 'pt-br'
		? 'Retrato de Shivapuri Baba (1826–1963)'
		: 'Portrait of Shivapuri Baba (1826–1963)';
---

<html lang={htmlLang[locale]} dir={dir[locale]}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="color-scheme" content="light dark" />
		<meta name="theme-color" media="(prefers-color-scheme: light)" content="#faf8f4" />
		<meta name="theme-color" media="(prefers-color-scheme: dark)" content="#15140f" />

		<title>{title}</title>
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />
		<link rel="sitemap" href="/sitemap-index.xml" />

		<!-- Language alternates (hreflang) -->
		{alternates.map((alt) => (
			<link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
		))}
		{xDefaultHref && <link rel="alternate" hreflang="x-default" href={xDefaultHref} />}

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:site_name" content="Shivapuri Baba" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:locale" content={ogLocale[locale]} />
		{LOCALES.filter((loc) => loc !== locale).map((loc) => (
			<meta property="og:locale:alternate" content={ogLocale[loc]} />
		))}
		<meta property="og:image" content={ogImageURL} />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={ogImageAlt} />

		<!-- Twitter -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageURL} />
		<meta name="twitter:image:alt" content={ogImageAlt} />
	</head>
	<body class="min-h-screen">
		<div class="mx-auto flex min-h-screen max-w-5xl flex-col px-6">
			<header
				class="flex flex-col items-center gap-y-3 py-6 text-center sm:flex-row sm:justify-between sm:text-left"
			>
				<a href={homePath} class="text-lg tracking-wide">Shivapuri Baba</a>
				<div
					class="flex w-full flex-col items-center gap-y-2 sm:w-auto sm:flex-row sm:gap-x-6"
				>
					<nav
						class="flex flex-wrap justify-center gap-x-5 gap-y-1 text-[color:var(--color-muted)]"
					>
						{
							navItems.map((item) => (
								<a
									href={item.href}
									aria-current={isActive(item.href) ? 'page' : undefined}
									class:list={[
										'whitespace-nowrap underline-offset-2 hover:text-[color:var(--color-text)] hover:underline',
										isActive(item.href) && 'text-[color:var(--color-text)]',
									]}
								>
									{item.label}
								</a>
							))
						}
					</nav>
					<details class="lang-switcher relative text-sm">
						<summary
							class="inline-flex cursor-pointer items-center gap-x-1 text-[color:var(--color-muted)] hover:text-[color:var(--color-text)]"
							aria-label={`${t.switcherLabel}: ${localeName[locale]}`}
						>
							<span lang={hreflang[locale]}>{localeName[locale]}</span>
							<svg width="10" height="10" viewBox="0 0 12 12" fill="none" aria-hidden="true">
								<path
									d="M2.5 4.5 6 8l3.5-3.5"
									stroke="currentColor"
									stroke-width="1.5"
									stroke-linecap="round"
									stroke-linejoin="round"
								/>
							</svg>
						</summary>
						<ul
							class="absolute top-full end-0 z-10 mt-2 min-w-40 border border-[color:var(--color-border)] bg-[color:var(--color-bg)] py-1 text-start"
						>
							{
								LOCALES.map((loc) => (
									<li>
										<a
											href={localeHref(loc)}
											hreflang={hreflang[loc]}
											lang={hreflang[loc]}
											aria-current={loc === locale ? 'page' : undefined}
											class:list={[
												'block whitespace-nowrap px-4 py-1.5 hover:bg-[color:var(--color-selection)] hover:text-[color:var(--color-text)]',
												loc === locale
													? 'font-medium text-[color:var(--color-text)]'
													: 'text-[color:var(--color-muted)]',
											]}
										>
											{localeName[loc]}
										</a>
									</li>
								))
							}
						</ul>
					</details>
				</div>
			</header>

			<main class="flex-1">
				<slot />
			</main>

			<footer
				class="mt-20 border-t border-[color:var(--color-border)] py-8 text-sm text-[color:var(--color-muted)]"
			>
				<p>Shivapuri Baba · 1826–1963</p>
				<p class="mt-1">
					{t.footerTagline} ·
					<a
						href={routes.about[locale]}
						class="underline-offset-2 hover:text-[color:var(--color-text)] hover:underline"
					>
						{t.footerAbout}
					</a>
				</p>
			</footer>
		</div>
	</body>
</html>
