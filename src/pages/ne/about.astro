---
import Layout from '../../layouts/Layout.astro';
import { Content as About } from '../../content/ne/about.md';
---

<Layout
	title="यस साइटको बारेमा — शिवपुरी बाबा"
	description="शिवपुरी बाबालाई समर्पित यस गैरनाफामुखी, खुला स्रोत साइटको बारेमा: यसका सिद्धान्तहरू — गैरनाफामुखी, प्राज्ञिक कठोरता, सम्भव भएसम्मको उत्कृष्ट पठन-अनुभव र खुला स्रोत — र यसको अनुमतिपत्र।"
>
	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<About />
			</article>
		</div>
	</div>
</Layout>
