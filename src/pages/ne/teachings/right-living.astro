---
import Layout from '../../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { Content as RightLiving } from '../../../content/ne/teachings/right-living.md';
import dhrubasthaliPhoto from '../../../assets/shivapuri-baba-dhrubasthali.jpg';

const site = Astro.site ?? Astro.url;
const canonicalURL = new URL(Astro.url.pathname, site);

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'शिक्षाहरू',
			item: new URL('/ne/teachings', site).href,
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'सद्जीवन (स्वधर्म)',
			item: canonicalURL.href,
		},
	],
};

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: 'सद्जीवन (स्वधर्म): श्री शिवपुरी बाबाको शिक्षा',
	about: { '@type': 'Person', name: 'Shivapuri Baba' },
	inLanguage: 'ne',
	isPartOf: { '@type': 'CollectionPage', name: 'शिक्षाहरू', url: new URL('/ne/teachings', site).href },
	url: canonicalURL.href,
};
---

<Layout
	title="सद्जीवन (स्वधर्म) — शिवपुरी बाबाको शिक्षा"
	description="शिवपुरी बाबाको केन्द्रीय शिक्षा, सद्जीवन वा स्वधर्म: तीन अनुशासन — शारीरिक, नैतिक र आध्यात्मिक —, केवल प्रथम-हस्त स्रोतहरूबाट खिचिएको, पूर्ण उद्धरणसहित।"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(breadcrumbSchema)}
		is:inline
	/>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(articleSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<nav
				class="mb-8 text-xs text-[color:var(--color-muted)]"
				aria-label="ब्रेडक्रम्ब नेभिगेसन"
			>
				<a href="/ne/teachings" class="hover:text-[color:var(--color-text)]">शिक्षाहरू</a>
				<span aria-hidden="true"> › </span>
				<span aria-current="page">सद्जीवन</span>
			</nav>

			<article class="prose">
				<figure>
					<Picture
						src={dhrubasthaliPhoto}
						formats={['avif', 'webp']}
						widths={[672, 1008, 1209]}
						sizes="(min-width: 768px) 672px, 100vw"
						alt="शिवपुरी बाबा आफ्नो ध्रुवस्थलीको आश्रममा बसेका, पशुपतिनाथ मन्दिरपछाडि, काठमाडौं"
						loading="eager"
					/>
					<figcaption>
						शिवपुरी बाबा आफ्नो ध्रुवस्थलीको आश्रममा, पशुपतिनाथ मन्दिरपछाडि,
						काठमाडौं। यो फोटो अनलाइन व्यापक रूपमा प्रचलनमा छ; यसको मूल स्रोत
						पत्ता लगाउन सकिएन।
					</figcaption>
				</figure>
				<RightLiving />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="पठन जारी राख्नुहोस्"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">अब यो पढ्नुहोस्</p>
				<ul class="space-y-3">
					<li>
						<a href="/ne/biography" class="underline-offset-2 hover:underline">जीवनी</a
						><span class="text-[color:var(--color-muted)]">
							— यो सिकाउने व्यक्तिको जीवन, प्रथम-हस्त स्रोतहरूबाट</span
						>
					</li>
					<li>
						<a href="/ne/books" class="underline-offset-2 hover:underline">पुस्तक र मिडिया</a
						><span class="text-[color:var(--color-muted)]">
							— स्रोतहरू कहाँ भेट्टाउने, छापामा वा नि:शुल्क उधारोका लागि</span
						>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
