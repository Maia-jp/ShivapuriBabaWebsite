---
import Layout from '../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { Content as Biography } from '../content/biography.md';
import bennettPhoto from '../assets/shivapuri-baba-bennett.jpg';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data helps search engines understand the page is about a person.
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shivapuri Baba',
	alternateName: ['Sri Govindananda Bharati', 'Govindananda Bharati'],
	birthDate: '1826',
	deathDate: '1963-01-28',
	birthPlace: 'South India',
	description:
		'Indian sage and sannyasin who, after long penance in the Narmada forest, attained God-realisation and taught the Right Life (Swadharma). He spent his final decades near Kathmandu, Nepal.',
	url: canonicalURL.href,
	sameAs: ['https://en.wikipedia.org/wiki/Shivapuri_Baba'],
};
---

<Layout
	title="Biography of Shivapuri Baba (1826–1963)"
	description="The life of Shivapuri Baba (Sri Govindananda Bharati, 1826–1963), drawn only from first-hand eyewitness sources — chiefly J. G. Bennett and Dr. Ainslie Meares — with full citations."
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(personSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<figure>
					<Picture
						src={bennettPhoto}
						formats={['avif', 'webp']}
						widths={[672, 1008, 1344]}
						sizes="(min-width: 768px) 672px, 100vw"
						alt="Shivapuri Baba, photographed during J. G. Bennett's visit to Kathmandu, 1961–62"
						loading="eager"
					/>
					<figcaption>
						Shivapuri Baba. Photograph courtesy of the
						<a
							href="https://www.jgbennett.org/tag/shivapuri-baba/"
							target="_blank"
							rel="noopener noreferrer">J. G. Bennett Foundation</a
						>.
					</figcaption>
				</figure>
				<Biography />
			</article>

			<nav
				class="font-sans mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="Continue reading"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">Continue</p>
				<ul class="space-y-3">
					<li>
						<a href="/teachings/right-living" class="underline-offset-2 hover:underline"
							>Right Living (Swadharma)</a
						><span class="text-[color:var(--color-muted)]"> — the teaching set out in full</span>
					</li>
					<li>
						<a href="/books" class="underline-offset-2 hover:underline">Books &amp; Media</a
						><span class="text-[color:var(--color-muted)]">
							— where to find the sources, in print or free to borrow</span
						>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
