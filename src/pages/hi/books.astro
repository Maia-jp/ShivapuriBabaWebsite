---
import Layout from '../../layouts/Layout.astro';
import { Content as Books } from '../../content/hi/books.md';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data: a reading list of the first-hand books, for richer search results.
const bennett = { '@type': 'Person', name: 'J. G. Bennett' };
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'शिवपुरी बाबा — पुस्तकें, मीडिया और संदर्भ',
	about: { '@type': 'Person', name: 'Shivapuri Baba' },
	inLanguage: 'hi',
	url: canonicalURL.href,
	hasPart: [
		{
			'@type': 'Book',
			name: 'Long Pilgrimage: The Life and Teaching of the Shivapuri Baba',
			author: [bennett, { '@type': 'Person', name: 'Thakur Lal Manandhar' }],
			datePublished: '1965',
			isbn: '978-1530624317',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Witness: The Story of a Search',
			author: bennett,
			datePublished: '1962',
		},
		{
			'@type': 'Book',
			name: 'The Shivapuri Baba and His Message: Four Lectures on a Great Indian Sage',
			author: bennett,
			isbn: '978-1533489319',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Strange Places, Simple Truths',
			author: { '@type': 'Person', name: 'Ainslie Meares' },
			datePublished: '1969',
		},
		{
			'@type': 'Book',
			name: 'Right Life: Teachings of the Shivapuri Baba',
			author: { '@type': 'Person', name: 'Renu Lal Singh' },
			datePublished: '1975',
			isbn: '0-900306-82-3',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Right Living: The Teaching of Sri Shivapuri Baba',
			author: { '@type': 'Person', name: 'Yogendra Bhakta Shrestha Malla' },
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Swadharma',
			author: { '@type': 'Person', name: 'Bishnu Prasad Timilsina' },
			inLanguage: 'ne',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
	],
};
---

<Layout
	title="शिवपुरी बाबा — पुस्तकें, मीडिया और संदर्भ"
	description="शिवपुरी बाबा पर पुस्तकें, ऑडियो और संदर्भ कहाँ पाएँ: प्रत्यक्ष विवरण (Bennett, Meares), शिष्यों के संकलन, 1962 की रिकॉर्डिंग और आगे का पठन — विक्रेताओं और निःशुल्क उधार के लिंक सहित।"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(collectionSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<Books />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="पठन जारी रखें"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">आगे पढ़ें</p>
				<ul class="space-y-3">
					<li>
						<a href="/hi/biography" class="underline-offset-2 hover:underline">जीवनी</a
						><span class="text-[color:var(--color-muted)]">
							— जीवन, केवल प्रत्यक्ष स्रोतों से लिया गया</span
						>
					</li>
					<li>
						<a href="/hi/teachings/right-living" class="underline-offset-2 hover:underline"
							>सम्यक् जीवन (स्वधर्म)</a
						><span class="text-[color:var(--color-muted)]"> — शिक्षा पूर्ण रूप में प्रतिपादित</span>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
