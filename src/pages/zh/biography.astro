---
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { Content as Biography } from '../../content/zh/biography.md';
import bennettPhoto from '../../assets/shivapuri-baba-bennett.jpg';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data helps search engines understand the page is about a person.
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shivapuri Baba',
	alternateName: ['Sri Govindananda Bharati', 'Govindananda Bharati'],
	birthDate: '1826',
	deathDate: '1963-01-28',
	birthPlace: 'South India',
	description:
		'印度圣者与遁世者，在讷尔默达森林中长期苦行之后证悟神，并教导正命之道（Swadharma）。他在尼泊尔加德满都附近度过了最后的数十年。',
	url: canonicalURL.href,
	inLanguage: 'zh-Hans',
	sameAs: ['https://en.wikipedia.org/wiki/Shivapuri_Baba'],
};
---

<Layout
	title="湿婆普里巴巴的传记（1826–1963）"
	description="湿婆普里巴巴（Sri Govindananda Bharati，1826–1963）的生平，仅取材于直接的目击者来源——主要是 J. G. Bennett 与 Dr. Ainslie Meares——并附有完整的引注。"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(personSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<figure>
					<Picture
						src={bennettPhoto}
						formats={['avif', 'webp']}
						widths={[672, 1008, 1344]}
						sizes="(min-width: 768px) 672px, 100vw"
						alt="湿婆普里巴巴，摄于 J. G. Bennett 在加德满都拜访期间，1961–62 年"
						loading="eager"
					/>
					<figcaption>
						湿婆普里巴巴。图片由
						<a
							href="https://www.jgbennett.org/tag/shivapuri-baba/"
							target="_blank"
							rel="noopener noreferrer">J. G. Bennett Foundation</a
						>提供。
					</figcaption>
				</figure>
				<Biography />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="继续阅读"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">延伸阅读</p>
				<ul class="space-y-3">
					<li>
						<a href="/zh/teachings/right-living" class="underline-offset-2 hover:underline"
							>正命之道（Swadharma）</a
						><span class="text-[color:var(--color-muted)]"> — 完整阐述的教导</span>
					</li>
					<li>
						<a href="/zh/books" class="underline-offset-2 hover:underline">书籍与媒体</a
						><span class="text-[color:var(--color-muted)]">
							— 到何处寻得这些来源，印刷本或免费借阅</span
						>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
