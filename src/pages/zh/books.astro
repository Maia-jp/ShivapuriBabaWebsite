---
import Layout from '../../layouts/Layout.astro';
import { Content as Books } from '../../content/zh/books.md';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data: a reading list of the first-hand books, for richer search results.
const bennett = { '@type': 'Person', name: 'J. G. Bennett' };
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: '湿婆普里巴巴 — 书籍、媒体与参考资料',
	about: { '@type': 'Person', name: 'Shivapuri Baba' },
	inLanguage: 'zh-Hans',
	url: canonicalURL.href,
	hasPart: [
		{
			'@type': 'Book',
			name: 'Long Pilgrimage: The Life and Teaching of the Shivapuri Baba',
			author: [bennett, { '@type': 'Person', name: 'Thakur Lal Manandhar' }],
			datePublished: '1965',
			isbn: '978-1530624317',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Witness: The Story of a Search',
			author: bennett,
			datePublished: '1962',
		},
		{
			'@type': 'Book',
			name: 'The Shivapuri Baba and His Message: Four Lectures on a Great Indian Sage',
			author: bennett,
			isbn: '978-1533489319',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Strange Places, Simple Truths',
			author: { '@type': 'Person', name: 'Ainslie Meares' },
			datePublished: '1969',
		},
		{
			'@type': 'Book',
			name: 'Right Life: Teachings of the Shivapuri Baba',
			author: { '@type': 'Person', name: 'Renu Lal Singh' },
			datePublished: '1975',
			isbn: '0-900306-82-3',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Right Living: The Teaching of Sri Shivapuri Baba',
			author: { '@type': 'Person', name: 'Yogendra Bhakta Shrestha Malla' },
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Swadharma',
			author: { '@type': 'Person', name: 'Bishnu Prasad Timilsina' },
			inLanguage: 'ne',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
	],
};
---

<Layout
	title="湿婆普里巴巴 — 书籍、媒体与参考资料"
	description="到何处寻得关于湿婆普里巴巴的书籍、音频与参考资料：第一手记述（Bennett、Meares）、门徒的汇编、1962 年的录音与延伸阅读——附有供应商与免费借阅的链接。"
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(collectionSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<Books />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="继续阅读"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">延伸阅读</p>
				<ul class="space-y-3">
					<li>
						<a href="/zh/biography" class="underline-offset-2 hover:underline">传记</a
						><span class="text-[color:var(--color-muted)]">
							— 生平，仅取材于第一手来源</span
						>
					</li>
					<li>
						<a href="/zh/teachings/right-living" class="underline-offset-2 hover:underline"
							>正命之道（Swadharma）</a
						><span class="text-[color:var(--color-muted)]"> — 完整阐述的教导</span>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
