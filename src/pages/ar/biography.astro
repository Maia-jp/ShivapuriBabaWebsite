---
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { Content as Biography } from '../../content/ar/biography.md';
import bennettPhoto from '../../assets/shivapuri-baba-bennett.jpg';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data helps search engines understand the page is about a person.
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shivapuri Baba',
	alternateName: ['Sri Govindananda Bharati', 'Govindananda Bharati'],
	birthDate: '1826',
	deathDate: '1963-01-28',
	birthPlace: 'South India',
	description:
		'حكيم وناسك (sannyasin) هندي بلغ، بعد تقشّفٍ طويل في غابة نَرمَدا، تحقيق الله وعلّم الحياة القويمة (Swadharma). وقضى عقوده الأخيرة قرب كاتماندو في نيبال.',
	url: canonicalURL.href,
	inLanguage: 'ar',
	sameAs: ['https://en.wikipedia.org/wiki/Shivapuri_Baba'],
};
---

<Layout
	title="سيرة شيفابوري بابا (1826–1963)"
	description="حياة شيفابوري بابا (Sri Govindananda Bharati، 1826–1963)، مستمدّة فقط من مصادر عيانية مباشرة — وعلى رأسها J. G. Bennett والدكتور Ainslie Meares — مع توثيقٍ كامل."
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(personSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<figure>
					<Picture
						src={bennettPhoto}
						formats={['avif', 'webp']}
						widths={[672, 1008, 1344]}
						sizes="(min-width: 768px) 672px, 100vw"
						alt="شيفابوري بابا، مصوَّراً أثناء زيارة J. G. Bennett لكاتماندو، 1961–62"
						loading="eager"
					/>
					<figcaption>
						شيفابوري بابا. الصورة مهداة من
						<a
							href="https://www.jgbennett.org/tag/shivapuri-baba/"
							target="_blank"
							rel="noopener noreferrer">J. G. Bennett Foundation</a
						>.
					</figcaption>
				</figure>
				<Biography />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="متابعة القراءة"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">اقرأ بعد ذلك</p>
				<ul class="space-y-3">
					<li>
						<a href="/ar/teachings/right-living" class="underline-offset-2 hover:underline"
							>الحياة القويمة (Swadharma)</a
						><span class="text-[color:var(--color-muted)]"> — التعليم معروضاً بكامله</span>
					</li>
					<li>
						<a href="/ar/books" class="underline-offset-2 hover:underline">الكتب والوسائط</a
						><span class="text-[color:var(--color-muted)]">
							— أين تجد المصادر، في الطباعة أو مجاناً للاستعارة</span
						>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
