---
import Layout from '../../layouts/Layout.astro';
import { Content as Books } from '../../content/ar/books.md';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data: a reading list of the first-hand books, for richer search results.
const bennett = { '@type': 'Person', name: 'J. G. Bennett' };
const collectionSchema = {
	'@context': 'https://schema.org',
	'@type': 'CollectionPage',
	name: 'شيفابوري بابا — الكتب والوسائط والمراجع',
	about: { '@type': 'Person', name: 'Shivapuri Baba' },
	inLanguage: 'ar',
	url: canonicalURL.href,
	hasPart: [
		{
			'@type': 'Book',
			name: 'Long Pilgrimage: The Life and Teaching of the Shivapuri Baba',
			author: [bennett, { '@type': 'Person', name: 'Thakur Lal Manandhar' }],
			datePublished: '1965',
			isbn: '978-1530624317',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Witness: The Story of a Search',
			author: bennett,
			datePublished: '1962',
		},
		{
			'@type': 'Book',
			name: 'The Shivapuri Baba and His Message: Four Lectures on a Great Indian Sage',
			author: bennett,
			isbn: '978-1533489319',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Strange Places, Simple Truths',
			author: { '@type': 'Person', name: 'Ainslie Meares' },
			datePublished: '1969',
		},
		{
			'@type': 'Book',
			name: 'Right Life: Teachings of the Shivapuri Baba',
			author: { '@type': 'Person', name: 'Renu Lal Singh' },
			datePublished: '1975',
			isbn: '0-900306-82-3',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Right Living: The Teaching of Sri Shivapuri Baba',
			author: { '@type': 'Person', name: 'Yogendra Bhakta Shrestha Malla' },
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
		{
			'@type': 'Book',
			name: 'Swadharma',
			author: { '@type': 'Person', name: 'Bishnu Prasad Timilsina' },
			inLanguage: 'ne',
			about: { '@type': 'Person', name: 'Shivapuri Baba' },
		},
	],
};
---

<Layout
	title="شيفابوري بابا — الكتب والوسائط والمراجع"
	description="أين تجد الكتب والتسجيلات الصوتية والمراجع عن شيفابوري بابا: روايات مباشرة (Bennett، Meares)، وتجميعات التلاميذ، وتسجيلات 1962، وقراءات إضافية — مع روابط للبائعين وللاستعارة المجانية."
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(collectionSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<Books />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="متابعة القراءة"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">اقرأ بعد ذلك</p>
				<ul class="space-y-3">
					<li>
						<a href="/ar/biography" class="underline-offset-2 hover:underline">السيرة</a
						><span class="text-[color:var(--color-muted)]">
							— الحياة، مستمدّة فقط من مصادر مباشرة</span
						>
					</li>
					<li>
						<a href="/ar/teachings/right-living" class="underline-offset-2 hover:underline"
							>الحياة القويمة (Swadharma)</a
						><span class="text-[color:var(--color-muted)]"> — التعليم معروضاً بكامله</span>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
