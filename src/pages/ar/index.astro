---
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import portrait from '../../assets/shivapuri-baba-portrait.jpg';
---

<Layout
	title="شيفابوري بابا — الحياة والتعليم والرياضات الثلاث"
	description="شيفابوري بابا (1826–1963)، حكيم جنوب الهند الذي بلغ تحقيق الله وعلّم الحياة القويمة — حملَ الجسد والعقل والذهن والروح إلى الكمال عبر ثلاث رياضات."
>
	<div class="py-10 md:py-16">
		<section class="md:grid md:grid-cols-[minmax(0,19rem)_1fr] md:gap-14">
				<!-- Portrait -->
				<figure class="mb-10 md:mb-0 md:sticky md:top-12 md:self-start">
					<div
						class="aspect-[3/4] w-full overflow-hidden border border-[color:var(--color-border)] bg-[color:var(--color-border)]"
					>
						<Picture
							src={portrait}
							formats={['avif', 'webp']}
							widths={[304, 480]}
							sizes="(min-width: 768px) 304px, 100vw"
							alt="صورة شيفابوري بابا"
							loading="eager"
							class="h-full w-full object-cover"
						/>
					</div>
					<figcaption class="mt-3 text-xs text-[color:var(--color-muted)]">
						شيفابوري بابا (1826–1963). هذه الصورة متداولة على الإنترنت ولم يتسنَّ
						إرجاعها إلى مصدر موثوق.
					</figcaption>
				</figure>

				<!-- Biography -->
				<article class="prose">
					<h1>شيفابوري بابا</h1>
					<p>
						وُلد شيفابوري بابا عام 1826 في أسرة برهمية ثرية ومتعلّمة في جنوب
						الهند، واتّخذ اسم التنسّك Govindananda Bharati حين صار ناسكاً
						(sannyasin).
					</p>
					<p>
						وصار جدّه، وهو منجّم محترَم، معلّمه. وإذ تخلّى عن ميراثه — الذي
						ناقله إلى أخته — تبع جدّه إلى الغابات عند منبع نهر نَرمَدا. وبعد وفاة
						جدّه انعزل هناك في خلوةٍ عميقة، وهكذا بدأ سعيه نحو الله.
					</p>
					<p>
						وبعد قرابة خمسة وعشرين عاماً من التقشّف الشديد، بلغ تحقيق الله — الوجهة
						النهائية التي يجب، كما قال، أن يبلغها كل إنسان.
					</p>
					<p>
						ثم، كما رغب جدّه، انطلق في حجٍّ عظيم حول العالم — كان معظمه على
						القدمين، على مدى نحو أربعين عاماً — قبل أن يستقرّ أخيراً في التلال قرب
						كاتماندو، حيث علّم الحياة القويمة لطالبين من كل صنف حتى وفاته عام 1963.
					</p>
					<p>ما هبة حياته القويمة؟</p>
					<figure>
						<blockquote>
							<p>
								الأمر بسيط جداً: حملُ الجسد والعقل والذهن والروح إلى
								الكمال.
							</p>
						</blockquote>
						<figcaption>— <cite>Shivapuri Baba</cite></figcaption>
					</figure>
					<p>
						<a href="/ar/biography">اقرأ السيرة الكاملة الموثَّقة ←</a>
					</p>
				</article>
			</section>

			<!-- The Three Disciplines -->
			<section class="mt-20 border-t border-[color:var(--color-border)] pt-16 md:mt-28">
				<div class="mx-auto max-w-2xl">
					<div class="prose">
						<h2>الرياضات الثلاث</h2>
						<p>
							قال شيفابوري بابا إن على كل كائنٍ حي أن يبلغ هذا الهدف ليصير حراً
							100% — لأن الإنسان، إذ هو تاج كل الكائنات الحية، هو الوحيد القادر
							على بلوغه. وكيف يُبلَغ؟ بممارسة الرياضات الثلاث: البدنية والذهنية
							والروحية.
						</p>

						<h3>الرياضة البدنية</h3>
						<p>
							تحمل الرياضة البدنية جسد الطالب وعقله إلى الكمال بجعل الجسد سليماً.
							وفي الوقت نفسه، بقصره نفسه على <em>سوادهارما</em> — واجبه المختار —
							وعدم انحرافه قطّ إلى الأنشطة العديمة الجدوى والضارّة، يجعل حياته
							ناجحة ومزدهرة. فيصير سعيداً ويعيش كملك؛ لكنه لا يستطيع بلوغ الأعلى،
							الله.
						</p>

						<h3>الرياضة الذهنية</h3>
						<p>
							تروّض الرياضة الذهنية الذهن، الذي يغدو نتيجةً لذلك ذا قدرةٍ آمرة
							ضابطة على الحواسّ ومتعلَّقاتها. فيتحرّر من ميوله ونفوره؛ ولا ينحرف
							إلى التكهّن ولا إلى الرغبات والأفعال غير المشروعة. وبهذا يصير يوغياً
							سعيداً مكتملاً، مفعماً بقوى خفيّة — لكنه مع ذلك يقصُر عن الله. ومع
							موته تتلاشى إنجازاته كلها.
						</p>

						<h3>الرياضة الروحية</h3>
						<p>
							تمكّنه الرياضة الأخيرة من اكتساب الصفات الإلهية. فروحه، إذ تُجرَّد
							من تماهيها مع الجسد والعقل والذهن — الأنا الزائف، القفص الذي كان
							مسجوناً فيه حتى ذلك الحين — تأتي لتعرف أناها الحقيقي:
							<em>Purusha</em>. ويهب الله، الأب، نعمته، التي تجعله أهلاً للطيران
							إلى ملكوته — مسقط رأسه، وحقّ مولده، وهدفه. فيصير
							<em>Purushottama</em>، الأعظم.
						</p>
						<p>
							فيصير حاضراً في كل مكان، عليماً بكل شيء، قديراً على كل شيء، مغبوطاً
							أبداً، وخالداً.
						</p>
						<p>
							يتوسّل شيفابوري بابا إلى كل إنسان أن يبلغ هذا، موصياً بممارسة
							الرياضات الثلاث معاً، لا منفردة. ففي البداية تغلب الأوليان؛ وفي
							النهاية تصير الثالثة هي الغالبة.
						</p>
						<p>
							<a href="/ar/teachings/right-living">اقرأ التعليم بكامله، مع المصادر ←</a>
						</p>
					</div>
				</div>
			</section>
	</div>
</Layout>
