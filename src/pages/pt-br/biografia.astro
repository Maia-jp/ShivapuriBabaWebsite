---
import Layout from '../../layouts/Layout.astro';
import { Picture } from 'astro:assets';
import { Content as Biography } from '../../content/pt-br/biografia.md';
import bennettPhoto from '../../assets/shivapuri-baba-bennett.jpg';

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? Astro.url);

// Structured data helps search engines understand the page is about a person.
const personSchema = {
	'@context': 'https://schema.org',
	'@type': 'Person',
	name: 'Shivapuri Baba',
	alternateName: ['Sri Govindananda Bharati', 'Govindananda Bharati'],
	birthDate: '1826',
	deathDate: '1963-01-28',
	birthPlace: 'South India',
	description:
		'Sábio e sannyasin indiano que, após longa penitência na floresta do Narmada, alcançou a Realização de Deus e ensinou a Vida Correta (Swadharma). Passou suas últimas décadas perto de Catmandu, no Nepal.',
	url: canonicalURL.href,
	sameAs: ['https://en.wikipedia.org/wiki/Shivapuri_Baba'],
};
---

<Layout
	title="Biografia de Shivapuri Baba (1826–1963)"
	description="A vida de Shivapuri Baba (Sri Govindananda Bharati, 1826–1963), extraída apenas de fontes oculares de primeira mão — sobretudo J. G. Bennett e o Dr. Ainslie Meares —, com citações completas."
>
	<script
		type="application/ld+json"
		set:html={JSON.stringify(personSchema)}
		is:inline
	/>

	<div class="py-10 md:py-16">
		<div class="mx-auto max-w-2xl">
			<article class="prose">
				<figure>
					<Picture
						src={bennettPhoto}
						formats={['avif', 'webp']}
						widths={[672, 1008, 1344]}
						sizes="(min-width: 768px) 672px, 100vw"
						alt="Shivapuri Baba, fotografado durante a visita de J. G. Bennett a Catmandu, 1961–62"
						loading="eager"
					/>
					<figcaption>
						Shivapuri Baba. Fotografia cortesia da
						<a
							href="https://www.jgbennett.org/tag/shivapuri-baba/"
							target="_blank"
							rel="noopener noreferrer">J. G. Bennett Foundation</a
						>.
					</figcaption>
				</figure>
				<Biography />
			</article>

			<nav
				class="mt-16 border-t border-[color:var(--color-border)] pt-8 text-sm"
				aria-label="Continuar a leitura"
			>
				<p class="mb-3 text-[color:var(--color-muted)]">Leia a seguir</p>
				<ul class="space-y-3">
					<li>
						<a href="/pt-br/ensinamentos/vida-correta" class="underline-offset-2 hover:underline"
							>Vida Correta (Swadharma)</a
						><span class="text-[color:var(--color-muted)]"> — o ensinamento exposto na íntegra</span>
					</li>
					<li>
						<a href="/pt-br/livros" class="underline-offset-2 hover:underline">Livros e Mídia</a
						><span class="text-[color:var(--color-muted)]">
							— onde encontrar as fontes, em catálogo ou para empréstimo gratuito</span
						>
					</li>
				</ul>
			</nav>
		</div>
	</div>
</Layout>
